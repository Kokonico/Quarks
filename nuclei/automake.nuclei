nuclei "automake", "1.16.5" do
  description "Tool for automatically generating Makefile.in files"
  homepage "https://www.gnu.org/software/automake/"
  license "GPL-2.0"
  category "sys-devel"
  
  source "https://ftp.gnu.org/gnu/automake/automake-1.16.5.tar.gz",
         checksum: "07bd24ad08a64bc17250ce09ec56e921d6343903943e99ccf63bbf0705e34605",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end