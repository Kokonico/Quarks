nuclei "garcon", "4.18.1" do
  description "garcon package"
  homepage ""
  license "Unknown"
  category "app"

  source "https://archive.xfce.org/xfce/4.18/src/garcon-4.18.1.tar.xz",
         checksum: "placeholder...",
         algorithm: "sha256"

  depends "intltool", "gobject-introspection", "gtk3", "libxfce4util"

  build_depends "intltool", "gobject-introspection", "gtk3", "libxfce4util"

  build do
    run "./configure --prefix=/usr --sysconfdir=/etc"
    run "make -j$(nproc)"
    run "make install"
  end
end
