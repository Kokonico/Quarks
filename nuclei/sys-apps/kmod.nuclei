nuclei "kmod", "31" do
  description "Linux kernel module management"
  homepage "https://github.com/kmod-project/kmod"
  license "GPL-2.0-or-later"
  category "sys-apps"
  
  source "https://mirrors.edge.kernel.org/pub/linux/utils/kernel/kmod/kmod-31.tar.xz",
         checksum: "placeholder...",
         algorithm: "sha256"
  
  build do
    configure "--prefix=/usr", "--libdir=/usr/lib64", "--sysconfdir=/etc"
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end
