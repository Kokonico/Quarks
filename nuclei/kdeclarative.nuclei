nuclei "kdeclarative", "6.7.0" do
  description "kdeclarative package"
  homepage ""
  license "Unknown"
  category "app"

  source "https://download.kde.org/stable/frameworks/6.7/kdeclarative-6.7.0.tar.xz",
         checksum: "placeholder...",
         algorithm: "sha256"

  depends "cmake", "ninja", "kconfig", "kcoreaddons", "ki18n", "kio", "kpackage", "kservice", "qtdeclarative", "qtquickcontrols"

  build_depends "cmake", "ninja", "kconfig", "kcoreaddons", "ki18n", "kio", "kpackage", "kservice", "qtdeclarative", "qtquickcontrols"

  build do
    run "cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DBUILD_TESTING=OFF"
    run "cmake --build build -j$(nproc)"
    run "cmake --install build"
  end
end
