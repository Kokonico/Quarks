nuclei "bison", "3.8.2" do
  description "General-purpose parser generator"
  homepage "https://www.gnu.org/software/bison/"
  license "GPL-3.0"
  category "sys-devel"
  
  source "https://ftp.gnu.org/gnu/bison/bison-3.8.2.tar.gz",
         checksum: "skip",
         algorithm: "sha256"
  
  depends "m4"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end