nuclei "kscreen", "6.1.0" do
  description "kscreen package"
  homepage ""
  license "Unknown"
  category "app"

  source "https://download.kde.org/stable/plasma/6.1.0/kscreen-6.1.0.tar.xz",
         checksum: "placeholder...",
         algorithm: "sha256"

  depends "cmake", "ninja", "kcoreaddons", "kdbusaddons", "kwayland", "libkscreen", "libxrandr"

  build_depends "cmake", "ninja", "kcoreaddons", "kdbusaddons", "kwayland", "libkscreen", "libxrandr"

  build do
    run "cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DBUILD_TESTING=OFF"
    run "cmake --build build -j$(nproc)"
    run "cmake --install build"
  end
end
