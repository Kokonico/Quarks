nuclei "vim", "9.0" do
  description "Highly configurable text editor"
  homepage "https://www.vim.org/"
  license "Vim"
  category "app-editors"
  
  source "https://github.com/vim/vim/archive/refs/tags/v9.0.2116.tar.gz",
         checksum: "a79783d6e2a46ba446fc695cdb1aa26be511f9db4826aa40b57c89b0392c59ba",
         algorithm: "sha256"
  
  build do
    run "cd src && sh ./configure --prefix=/opt/quarks --with-features=normal --disable-gui --disable-gpm && cd .."
    make
    install "cd src && make DESTDIR=${DESTDIR} install"
  end
end
