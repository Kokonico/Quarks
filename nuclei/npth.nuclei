nuclei "npth", "1.6" do
  description "New portable threads library"
  homepage "https://git.gnupg.org/cgi-bin/gitweb.cgi?p=npth.git"
  license "LGPL-2.1"
  category "dev-libs"
  
  source "https://www.gnupg.org/ftp/gcrypt/npth/npth-1.6.tar.bz2",
         checksum: "skip",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end