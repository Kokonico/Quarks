nuclei "xfce4-notifyd", "4.18.1" do
  description "xfce4-notifyd package"
  homepage ""
  license "Unknown"
  category "app"

  source "https://archive.xfce.org/xfce/4.18/src/xfce4-notifyd-4.18.1.tar.xz",
         checksum: "placeholder...",
         algorithm: "sha256"

  depends "intltool", "gtk3", "libxfce4util", "libxfce4ui", "xfconf", "libnotify", "libxfce4menu"

  build_depends "intltool", "gtk3", "libxfce4util", "libxfce4ui", "xfconf", "libnotify", "libxfce4menu"

  build do
    run "./configure --prefix=/usr --sysconfdir=/etc"
    run "make -j$(nproc)"
    run "make install"
  end
end
