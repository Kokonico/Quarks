nuclei "icu", "75.1" do
  description "icu package"
  homepage ""
  license "Unknown"
  category "app"

  source "https://github.com/unicode-org/icu/releases/download/release-75-1/icu4c-75-1-src.tgz",
         checksum: "placeholder...",
         algorithm: "sha256"

  depends "python3"

  build_depends "python3"

  build do
    run "./configure --prefix=/usr --enable-static --disable-samples --disable-tests"
    run "make -j$(nproc)"
    run "make install"
  end
end
