#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  LINK="$(readlink "$SCRIPT_PATH")"
  [[ "$LINK" = /* ]] || LINK="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)/$LINK"
  SCRIPT_PATH="$LINK"
done
ROOT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"

RUBY_BIN="${PHOTON_RUBY:-ruby}"
ENTRY="$ROOT_DIR/src/photon.rb"

die() { echo "!!! $*" >&2; exit 1; }

[[ -f "$ENTRY" ]] || die "Photon entrypoint missing: $ENTRY"
command -v "$RUBY_BIN" >/dev/null 2>&1 || die "ruby not found (tried: $RUBY_BIN)"

real_home="${HOME}"
if [[ -n "${SUDO_USER:-}" ]]; then
  real_home="$(getent passwd "$SUDO_USER" | cut -d: -f6 || true)"
  [[ -n "$real_home" ]] || real_home="$HOME"
fi

export PHOTON_STATE_ROOT="${PHOTON_STATE_ROOT:-$real_home/.local/state/photon}"

mkdir -p \
  "$PHOTON_STATE_ROOT/var/db" \
  "$PHOTON_STATE_ROOT/var/cache/photon" \
  "$PHOTON_STATE_ROOT/var/tmp/photon" \
  "$PHOTON_STATE_ROOT/var/log/photon" 2>/dev/null || true

is_writable_or_creatable() {
  local path="$1"
  if [[ -e "$path" ]]; then
    [[ -w "$path" ]]
  else
    [[ -w "$(dirname "$path")" ]]
  fi
}

if [[ -z "${PHOTON_ROOT:-}" ]]; then
  if [[ "$(id -u)" -eq 0 ]]; then
    export PHOTON_ROOT="/opt/photon"
  else
    if is_writable_or_creatable "/opt/photon"; then
      export PHOTON_ROOT="/opt/photon"
    else
      export PHOTON_ROOT="$real_home/.local/photon"
    fi
  fi
fi

cmd=""
for a in "$@"; do
  [[ "$a" == "--" ]] && break
  if [[ "$a" != -* ]]; then
    cmd="$a"
    break
  fi
done

needs_root=0
case "$cmd" in
  install|i|emerge|remove|uninstall|r|rm|unmerge|clean|eclean|setup-path)
    needs_root=1
    ;;
esac

if [[ "$needs_root" -eq 1 && "$(id -u)" -ne 0 ]]; then
  if [[ "$PHOTON_ROOT" == "/opt/photon"* && ! -w "$PHOTON_ROOT" && -z "${PHOTON_NO_SUDO:-}" ]]; then
    echo ">>> Photon needs admin permissions to write into: $PHOTON_ROOT" >&2
    echo ">>> Re-running with sudo (state stays in: $PHOTON_STATE_ROOT)" >&2

    exec sudo env \
      PHOTON_ROOT="$PHOTON_ROOT" \
      PHOTON_STATE_ROOT="$PHOTON_STATE_ROOT" \
      PHOTON_JOBS="${PHOTON_JOBS:-}" \
      PHOTON_VERBOSE="${PHOTON_VERBOSE:-}" \
      PHOTON_QUIET="${PHOTON_QUIET:-}" \
      PHOTON_DEBUG="${PHOTON_DEBUG:-}" \
      PHOTON_WARNINGS="${PHOTON_WARNINGS:-}" \
      PHOTON_TRACE_SYSTEM="${PHOTON_TRACE_SYSTEM:-}" \
      PHOTON_NUCLEI_PATHS="${PHOTON_NUCLEI_PATHS:-}" \
      PHOTON_REPO_URLS="${PHOTON_REPO_URLS:-}" \
      PHOTON_ALLOW_INSECURE="${PHOTON_ALLOW_INSECURE:-}" \
      PHOTON_ALLOW_DUPLICATES="${PHOTON_ALLOW_DUPLICATES:-}" \
      "$RUBY_BIN" "$ENTRY" "$@"
  fi
fi

exec "$RUBY_BIN" "$ENTRY" "$@"
