nuclei "pam", "1.6.0" do
  description "Linux Pluggable Authentication Modules"
  homepage "http://www.linux-pam.org/"
  license "BSD"
  category "sys-libs"
  
  source "https://github.com/linux-pam/linux-pam/releases/download/v1.6.0/Linux-PAM-1.6.0.tar.xz",
         checksum: "fff4a34e5bbee77e2e8f1992f27631e2329bcbf8a0563ddeb5c3389b4e3169ad",
         algorithm: "sha256"
  
  configure "--disable-doc"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end