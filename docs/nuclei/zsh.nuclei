nuclei "zsh", "5.9" do
  description "UNIX shell (command interpreter)"
  homepage "https://www.zsh.org/"
  license "MIT"
  category "app-shells"
  build_system :make
  
  source "https://sourceforge.net/projects/zsh/files/zsh/5.9/zsh-5.9.tar.xz",
         checksum: "9b8d1ecedd5b5e81fbf1918e876752a7dd948e05c1a0dba10ab863842d45acd5",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end
