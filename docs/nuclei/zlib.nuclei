nuclei "zlib", "1.3.1" do
  description "Standard compression library"
  homepage "https://www.zlib.net/"
  license "zlib"
  category "dev-libs"
  build_system :make
  
  source "https://www.zlib.net/zlib-1.3.1.tar.gz",
         checksum: "9a93b2b7dfdac77ceba5a558a580e74667dd6fede4585b91eefb60f03b72df23",
         algorithm: "sha256"
  
  build do
    run "./configure --prefix=/"
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end
