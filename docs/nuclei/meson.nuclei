nuclei "meson", "1.3.1" do
  description "High productivity build system"
  homepage "https://mesonbuild.com/"
  license "Apache-2.0"
  category "dev-util"
  
  source "https://github.com/mesonbuild/meson/releases/download/1.3.1/meson-1.3.1.tar.gz",
         checksum: "6020568bdede1643d4fb41e28215be38eff5d52da28ac7d125457c59e0032ad7",
         algorithm: "sha256"
  
  depends "python3", "ninja"
  
  build do
    install "python3 setup.py install --root=${DESTDIR} --prefix=/"
  end
end