nuclei "sed", "4.9" do
  description "GNU stream editor"
  homepage "https://www.gnu.org/software/sed/"
  license "GPL-3.0"
  category "sys-apps"
  
  source "https://mirrors.kernel.org/gnu/sed/sed-4.9.tar.gz",
         checksum: "d1478a18f033a73ac16822901f6533d30b6be561bcbce46ffd7abce93602282e",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end