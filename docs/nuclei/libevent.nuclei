nuclei "libevent", "2.1.12" do
  description "Event notification library"
  homepage "https://libevent.org/"
  license "BSD"
  category "dev-libs"
  build_system :make
  
  source "https://github.com/libevent/libevent/releases/download/release-2.1.12-stable/libevent-2.1.12-stable.tar.gz",
         checksum: "92e6de1be9ec176428fd2367677e61ceffc2ee1cb119035037a27d346b0403bb",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end
