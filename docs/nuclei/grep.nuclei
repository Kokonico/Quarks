nuclei "grep", "3.11" do
  description "GNU grep, egrep and fgrep"
  homepage "https://www.gnu.org/software/grep/"
  license "GPL-3.0"
  category "sys-apps"
  
  source "https://mirrors.kernel.org/gnu/grep/grep-3.11.tar.gz",
         checksum: "1f31014953e71c3cddcedb97692ad7620cb9d6d04fbdc19e0d8dd836f87622bb",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end