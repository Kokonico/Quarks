nuclei "portaudio", "19.7.0" do
  description "Portable cross-platform audio I/O library"
  homepage "http://www.portaudio.com/"
  license "MIT"
  category "media-libs"
  
  source "http://files.portaudio.com/archives/pa_stable_v190700_20210406.tgz",
         checksum: "47efbf42c77c19a05d22e627d42873e991ec0c1357219c0d74ce6a2948cb2def",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end