nuclei "duktape", "2.7.0" do
  description "Embeddable JavaScript engine"
  homepage "https://duktape.org/"
  license "MIT"
  category "dev-lang"
  
  source "https://duktape.org/duktape-2.7.0.tar.xz",
         checksum: "90f8d2fa8b5567c6899830ddef2c03f3c27960b11aca222fa17aa7ac613c2890",
         algorithm: "sha256"
  
  build do
    run "make -f Makefile.sharedlibrary"
    install "install -Dm755 libduktape.so.207 ${DESTDIR}/lib/libduktape.so.207"
    install "ln -sf libduktape.so.207 ${DESTDIR}/lib/libduktape.so"
    install "install -Dm644 duktape.h ${DESTDIR}/include/duktape.h"
  end
end