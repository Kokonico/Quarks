nuclei "mpfr", "4.2.1" do
  description "Multiple-precision floating-point library"
  homepage "https://www.mpfr.org/"
  license "LGPL-3.0"
  category "dev-libs"
  build_system :make
  
  source "https://ftp.gnu.org/gnu/mpfr/mpfr-4.2.1.tar.xz",
         checksum: "277807353a6726978996945af13e52829e3abd7a9a5b7fb2793894e18f1fcbb2",
         algorithm: "sha256"
  
  depends "gmp"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end
