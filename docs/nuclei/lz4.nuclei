nuclei "lz4", "1.9.4" do
  description "Extremely fast compression algorithm"
  homepage "https://lz4.github.io/lz4/"
  license "BSD"
  category "app-arch"
  
  source "https://github.com/lz4/lz4/archive/v1.9.4.tar.gz",
         checksum: "0b0e3aa07c8c063ddf40b082bdf7e37a1562bda40a0ff5272957f3e987e0e54b",
         algorithm: "sha256"
  
  build do
    make
    install "make DESTDIR=${DESTDIR} PREFIX=/ install"
  end
end