nuclei "expat", "2.5.0" do
  description "XML parser library"
  homepage "https://libexpat.github.io/"
  license "MIT"
  category "dev-libs"
  
  source "https://github.com/libexpat/libexpat/releases/download/R_2_5_0/expat-2.5.0.tar.gz",
         checksum: "6b902ab103843592be5e99504f846ec109c1abb692e85347587f237a4ffa1033",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end