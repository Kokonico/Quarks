nuclei "fd", "9.0.0" do
  description "Simple, fast alternative to find"
  homepage "https://github.com/sharkdp/fd"
  license "MIT"
  category "sys-apps"
  
  source "https://github.com/sharkdp/fd/archive/v9.0.0.tar.gz",
         checksum: "306d7662994e06e23d25587246fa3fb1f528579e42a84f5128e75feec635a370",
         algorithm: "sha256"
  
  build do
    run "cargo build --release"
    install "install -Dm755 target/release/fd ${DESTDIR}/bin/fd"
  end
end