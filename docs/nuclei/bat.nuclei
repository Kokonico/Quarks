nuclei "bat", "0.24.0" do
  description "Cat clone with syntax highlighting"
  homepage "https://github.com/sharkdp/bat"
  license "MIT"
  category "sys-apps"
  
  source "https://github.com/sharkdp/bat/archive/v0.24.0.tar.gz",
         checksum: "907554a9eff239f256ee8fe05a922aad84febe4fe10a499def72a4557e9eedfb",
         algorithm: "sha256"
  
  build do
    run "cargo build --release"
    install "install -Dm755 target/release/bat ${DESTDIR}/bin/bat"
  end
end