nuclei "scons", "4.6.0" do
  description "Software construction tool"
  homepage "https://scons.org/"
  license "MIT"
  category "dev-util"
  
  source "https://sourceforge.net/projects/scons/files/scons/4.6.0/SCons-4.6.0.tar.gz",
         checksum: "7db28958b188b800f803c287d0680cc3ac7c422ed0b1cf9895042c52567803ec",
         algorithm: "sha256"
  
  depends "python3"
  
  build do
    install "python3 setup.py install --root=${DESTDIR} --prefix=/"
  end
end