nuclei "libunistring", "1.1" do
  description "Library for manipulating Unicode strings"
  homepage "https://www.gnu.org/software/libunistring/"
  license "LGPL-3.0"
  category "dev-libs"
  
  source "https://mirrors.kernel.org/gnu/libunistring/libunistring-1.1.tar.gz",
         checksum: "a2252beeec830ac444b9f68d6b38ad883db19919db35b52222cf827c385bdb6a",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end