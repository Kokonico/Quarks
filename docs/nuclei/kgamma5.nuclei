nuclei "kgamma5", "6.1.0" do
  description "kgamma5 package"
  homepage ""
  license "Unknown"
  category "app"

  source "https://download.kde.org/stable/plasma/6.1.0/kgamma5-6.1.0.tar.xz",
         checksum: "placeholder...",
         algorithm: "sha256"

  depends "cmake", "ninja", "kcoreaddons", "kdbusaddons", "ki18n", "kio", "knotifications", "kservice", "libxrandr", "libxvmc", "libxxf86vm"

  build_depends "cmake", "ninja", "kcoreaddons", "kdbusaddons", "ki18n", "kio", "knotifications", "kservice", "libxrandr", "libxvmc", "libxxf86vm"

  build do
    run "cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DBUILD_TESTING=OFF"
    run "cmake --build build -j$(nproc)"
    run "cmake --install build"
  end
end
