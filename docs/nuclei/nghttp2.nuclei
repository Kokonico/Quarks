nuclei "nghttp2", "1.58.0" do
  description "HTTP/2 C library"
  homepage "https://nghttp2.org/"
  license "MIT"
  category "net-libs"
  
  source "https://github.com/nghttp2/nghttp2/releases/download/v1.58.0/nghttp2-1.58.0.tar.gz",
         checksum: "9ebdfbfbca164ef72bdf5fd2a94a4e6dfb54ec39d2ef249aeb750a91ae361dfb",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end