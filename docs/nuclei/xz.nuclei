nuclei "xz", "5.4.5" do
  description "Free general-purpose data compression software"
  homepage "https://tukaani.org/xz/"
  license "Public-Domain"
  category "app-arch"
  
  source "https://tukaani.org/xz/xz-5.4.5.tar.gz",
         checksum: "135c90b934aee8fbc0d467de87a05cb70d627da36abe518c357a873709e5b7d6",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end