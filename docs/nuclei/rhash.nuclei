nuclei "rhash", "1.4.4" do
  description "Utility for computing hash sums and magnet links"
  homepage "https://rhash.sourceforge.net/"
  license "BSD"
  category "app-crypt"
  
  source "https://github.com/rhash/RHash/archive/v1.4.4.tar.gz",
         checksum: "8e7d1a8ccac0143c8fe9b68ebac67d485df119ea17a613f4038cda52f84ef52a",
         algorithm: "sha256"
  
  build do
    run "./configure --prefix=/"
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end