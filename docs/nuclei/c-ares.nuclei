nuclei "c-ares", "1.34.6" do
  description "C library for asynchronous DNS requests"
  homepage "https://c-ares.org/"
  license "MIT"
  category "net-dns"
  
  source "https://github.com/c-ares/c-ares/releases/download/v1.34.6/c-ares-1.34.6.tar.gz",
         checksum: "912dd7cc3b3e8a79c52fd7fb9c0f4ecf0aaa73e45efda880266a2d6e26b84ef5",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end