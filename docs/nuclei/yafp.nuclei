nuclei "yafp", "1.0.0" do
  description "YAFP - Yet Another Fetch Program"
  homepage "https://github.com/RobertFlexx/YAFP"
  license "MIT"
  category "app-misc"
  
  source "https://github.com/RobertFlexx/YAFP/archive/refs/heads/main.tar.gz",
         checksum: "70723c6b0ca19d9de0589e94bd215418c6e39d21d97e7f863ce9ba11063b5bba",
         algorithm: "sha256"
  
  build do
    run "make"
    install "install -Dm755 yafp ${DESTDIR}/bin/yafp"
  end
end
