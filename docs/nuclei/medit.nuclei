nuclei "medit", "1.0.0" do
  description "medit - Micro Edit by Kokonico"
  homepage "https://github.com/Kokonico/medit"
  license "MIT"
  category "app-editors"
  
  source "https://github.com/Kokonico/medit/archive/refs/heads/main.tar.gz",
         checksum: "70723c6b0ca19d9de0589e94bd215418c6e39d21d97e7f863ce9ba11063b5bba",
         algorithm: "sha256"
  
  build do
    run "make"
    install "install -Dm755 medit ${DESTDIR}/bin/medit"
  end
end