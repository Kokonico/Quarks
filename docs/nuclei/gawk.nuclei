nuclei "gawk", "5.3.0" do
  description "GNU awk pattern-matching language"
  homepage "https://www.gnu.org/software/gawk/"
  license "GPL-3.0"
  category "sys-apps"
  
  source "https://mirrors.kernel.org/gnu/gawk/gawk-5.3.0.tar.gz",
         checksum: "378f8864ec21cfceaa048f7e1869ac9b4597b449087caf1eb55e440d30273336",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end