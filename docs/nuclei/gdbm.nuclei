nuclei "gdbm", "1.23" do
  description "GNU database library"
  homepage "https://www.gnu.org/software/gdbm/"
  license "GPL-3.0"
  category "sys-libs"
  
  source "https://mirrors.kernel.org/gnu/gdbm/gdbm-1.23.tar.gz",
         checksum: "74b1081d21fff13ae4bd7c16e5d6e504a4c26f7cde1dca0d963a484174bbcacd",
         algorithm: "sha256"
  
  configure "--enable-libgdbm-compat"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end