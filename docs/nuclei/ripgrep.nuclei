nuclei "ripgrep", "14.0.3" do
  description "Line-oriented search tool (faster grep)"
  homepage "https://github.com/BurntSushi/ripgrep"
  license "MIT"
  category "sys-apps"
  
  source "https://github.com/BurntSushi/ripgrep/archive/14.0.3.tar.gz",
         checksum: "f5794364ddfda1e0411ab6cad6dd63abe3a6b421d658d9fee017540ea4c31a0e",
         algorithm: "sha256"
  
  build do
    run "cargo build --release"
    install "install -Dm755 target/release/rg ${DESTDIR}/bin/rg"
  end
end