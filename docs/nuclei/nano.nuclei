nuclei "nano", "7.2" do
  description "Small, friendly text editor"
  homepage "https://www.nano-editor.org/"
  license "GPL-3.0"
  category "app-editors"
  
  source "https://www.nano-editor.org/dist/v7/nano-7.2.tar.xz",
         checksum: "86f3442768bd2873cec693f83cdf80b4b444ad3cc14760b74361474fc87a4526",
         algorithm: "sha256"
  
  build do
    configure
    make
    install "make DESTDIR=${DESTDIR} install"
  end
end
