nuclei "zstd", "1.5.5" do
  description "Fast real-time compression algorithm"
  homepage "https://facebook.github.io/zstd/"
  license "BSD"
  category "app-arch"
  
  source "https://github.com/facebook/zstd/releases/download/v1.5.5/zstd-1.5.5.tar.gz",
         checksum: "9c4396cc829cfae319a6e2615202e82aad41372073482fce286fac78646d3ee4",
         algorithm: "sha256"
  
  build do
    make
    install "make DESTDIR=${DESTDIR} PREFIX=/ install"
  end
end