nuclei "plasma-browser-integration", "6.1.0" do
  description "plasma-browser-integration package"
  homepage ""
  license "Unknown"
  category "app"

  source "https://download.kde.org/stable/plasma/6.1.0/plasma-browser-integration-6.1.0.tar.xz",
         checksum: "placeholder...",
         algorithm: "sha256"

  depends "cmake", "ninja", "kcoreaddons", "kio", "knotifications", "krunner"

  build_depends "cmake", "ninja", "kcoreaddons", "kio", "knotifications", "krunner"

  build do
    run "cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr"
    run "cmake --build build -j$(nproc)"
    run "cmake --install build"
  end
end
